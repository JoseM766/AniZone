<div class="page-header">
  <h1>🛒 Mi Carrito</h1>
  <p>ID del carrito: <code>{{cartId}}</code></p>
</div>

{{#if products.length}}
<div class="cart-container">
  <div class="cart-items">
    {{#each products}}
    <div class="cart-item" id="item-{{this.product._id}}">
      <div class="cart-item-thumb">
        {{#if this.product.thumbnails.[0]}}
          <img src="{{this.product.thumbnails.[0]}}" alt="{{this.product.title}}" />
        {{else}}
          <div class="no-thumb small">🎌</div>
        {{/if}}
      </div>
      <div class="cart-item-info">
        <h3>{{this.product.title}}</h3>
        <span class="badge">{{this.product.category}}</span>
        <p class="price">${{this.product.price}} c/u</p>
        <div class="qty-controls">
          <button onclick="changeQty('{{../cartId}}', '{{this.product._id}}', {{this.quantity}}, -1)" class="btn btn-outline btn-sm">−</button>
          <span class="qty-display">{{this.quantity}}</span>
          <button onclick="changeQty('{{../cartId}}', '{{this.product._id}}', {{this.quantity}}, 1)" class="btn btn-outline btn-sm">+</button>
          <button onclick="removeProduct('{{../cartId}}', '{{this.product._id}}')" class="btn btn-danger btn-sm" style="margin-left:.5rem">🗑️ Quitar</button>
        </div>
        <p>Subtotal: <strong>${{multiply this.product.price this.quantity}}</strong></p>
      </div>
    </div>
    {{/each}}
  </div>

  <div class="cart-summary">
    <h2>Resumen</h2>
    <div class="summary-row">
      <span>Total</span>
      <span class="total-price">${{total}}</span>
    </div>
    <button onclick="clearCart()" class="btn btn-danger">🗑️ Vaciar carrito</button>
    <a href="/products" class="btn btn-primary">Seguir comprando</a>
  </div>
</div>
{{else}}
<div class="empty-state">
  <p>😢 Tu carrito está vacío</p>
  <a href="/products" class="btn btn-primary">Ver productos</a>
</div>
{{/if}}

<script>
  const cartId = '{{cartId}}';

  async function changeQty(cartId, productId, currentQty, delta) {
    const newQty = currentQty + delta;
    if (newQty < 1) {
      removeProduct(cartId, productId);
      return;
    }
    const res = await fetch(`/api/carts/${cartId}/products/${productId}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ quantity: newQty })
    });
    const data = await res.json();
    if (data.status === 'success') location.reload();
  }

  async function removeProduct(cartId, productId) {
    if (!confirm('¿Quitás este producto del carrito?')) return;
    const res = await fetch(`/api/carts/${cartId}/products/${productId}`, {
      method: 'DELETE'
    });
    const data = await res.json();
    if (data.status === 'success') location.reload();
  }

  async function clearCart() {
    if (!confirm('¿Vaciar el carrito completo?')) return;
    const res = await fetch(`/api/carts/${cartId}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.status === 'success') location.reload();
  }
</script>